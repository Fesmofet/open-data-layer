# PostgreSQL + PostGIS (postgis/postgis image)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=odl
POSTGRES_PORT=5432

# Apps (DATABASE_URL must match Postgres user/password/db/port above when using docker-compose)
DATABASE_URL=postgres://postgres:postgres@postgres:5432/odl
QUERY_API_PORT=3000
