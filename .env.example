# MongoDB (query-mongo app)
MONGO_URI=mongodb://localhost:27017/odl-query
QUERY_STRATEGY=composition

# PostgreSQL + PostGIS (query-postgres app)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/odl_query
# QUERY_STRATEGY=composition

# Seed (override in docker-compose for full benchmark: SEED_COUNT=1000000)
# SEED_COUNT=1000000
# SEED_SEED=42

# App ports (defaults: query-mongo 3001, query-postgres 3002)
PORT=3001
# PORT=3002
