        "nx",
        "serve",
        "query-mongo"
      ],
      "env": {
        "NODE_OPTIONS": "--inspect=9231"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/apps/query-mongo/dist/**/*.(m|c|)js",
        "!**/node_modules/**"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug query-postgres with Nx",
      "runtimeExecutable": "pnpm exec",
      "runtimeArgs": [
        "nx",
        "serve",
        "query-postgres"
      ],
      "env": {
        "NODE_OPTIONS": "--inspect=9232"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/apps/query-postgres/dist/**/*.(m|c|)js",
        "!**/node_modules/**"
      ]
    }
  ]
}
