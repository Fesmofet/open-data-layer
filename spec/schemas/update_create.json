{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-data/schemas/update_create.json",
  "title": "update_create",
  "description": "Payload for od.updates.v1 action update_create",
  "type": "object",
  "required": ["v", "action", "update_id", "object_id", "update_type", "creator", "transaction_id"],
  "additionalProperties": true,
  "properties": {
    "v": { "type": "integer", "const": 1 },
    "action": { "type": "string", "const": "update_create" },
    "update_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "object_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "update_type": { "type": "string", "minLength": 1, "maxLength": 64 },
    "name": { "type": "string" },
    "body": { "type": "string" },
    "locale": { "type": "string", "maxLength": 32 },
    "creator": { "type": "string", "minLength": 1, "maxLength": 32 },
    "transaction_id": { "type": "string", "minLength": 1, "maxLength": 64 }
  }
}
